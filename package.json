{
  "name": "practicas-de-chino",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "PWA para reactivar y practicar chino mandarín (HSK 5-6, chengyu) — vocabulario SRS, lectura, escucha y escritura de hanzi.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.0.0"
  }
}
